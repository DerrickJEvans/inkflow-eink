# E-Ink Dashboard Python Client Configuration
# Copy this file to .env and adjust your settings

# 1. Server Configuration
TRMNL_SERVER_IP=192.168.1.100
TRMNL_SERVER_PORT=5000

# 2. Device Settings
TRMNL_DEVICE_NAME=Living Room Pi
TRMNL_DEVICE_ID=dynamic_mac

# 3. Screen & Driver Selection
# Supported options: '4in26' (Recommended), '7in5', '4in2', '2in9'
TRMNL_SCREEN_TYPE=4in26

# Supported driver types: 'waveshare' (for physical SPI E-Paper), 'inky', 'mock'
TRMNL_DISPLAY_TYPE=waveshare

# 4. Color Contrast & Sleep Options
# Set to 'true' if your screen displays inverted (white text on a black background)
TRMNL_INVERT_COLORS=false

# Fallback Poll Interval (in seconds) if the server doesn't respond with a rate
TRMNL_DEFAULT_POLL_INTERVAL=1800

# Set to 'false' to prevent putting the screen to sleep (helps if image fades after sleep)
TRMNL_SLEEP_AFTER=true

# Delay in seconds to wait for pixels to stabilize before calling sleep()
TRMNL_SLEEP_DELAY=2.0

# 5. Manual Hardware Resolution Overrides (optional, leave blank to use defaults)
TRMNL_WIDTH=
TRMNL_HEIGHT=
TRMNL_WAVESHARE_MODEL=

# 6. MPR121 Capacitive Touch Settings (Optional)
# Set to 'true' to enable capacitive touch buttons via MPR121 module on I2C bus
TRMNL_MPR121_ENABLED=false
# MPR121 electrode/input pins for previous/next actions
TRMNL_MPR121_PREV_PIN=6
TRMNL_MPR121_NEXT_PIN=7
TRMNL_MPR121_SETUP_PIN=9
TRMNL_MPR121_DIAG_PIN=8

# 7. Refresh Mode Settings
# Interval of polls before forcing a full refresh (clear flashing). Set to 1 to force full refresh every poll.
TRMNL_FULL_REFRESH_INTERVAL=10

